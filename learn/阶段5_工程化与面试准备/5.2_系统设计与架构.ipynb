    print("   - 适用: 流量波动大的场景")
    \n    print("\\n4. 边缘计算:")
    print("   - 特点: 计算靠近数据源")
    print("   - 优势: 低延迟、节省带宽")
    print("   - 适用: 实时应用、IoT设备")

